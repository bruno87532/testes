generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Status {
  COMPLETED
  PROGRESS
  STOP
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  task Task[]
}

model Task {
  id          String @id @default(uuid())
  description String
  status      Status

  idUser String
  userId User   @relation(fields: [idUser], references: [id], onDelete: Cascade)
}
